<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#05050A">

    <SurfaceView
        android:id="@+id/gameSurface"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:layout_gravity="top|center_horizontal"
        android:background="#99000000"
        android:padding="16dp"
        android:elevation="10dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvOrbs"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔮 Orbs: 0"
            android:textColor="#00FFFF"
            android:textSize="28sp"
            android:textStyle="bold"
            android:fontFamily="serif"/>
    </LinearLayout>

    <TextView
        android:id="@+id/btnOpenShop"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginBottom="40dp"
        android:layout_marginEnd="40dp"
        android:text="SHOP"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold"
        android:background="#802E1A47"
        android:elevation="8dp"
        android:padding="16dp"
        android:fontFamily="serif"/>

    <FrameLayout
        android:id="@+id/shopOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F2080812"
        android:elevation="20dp"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:padding="32dp"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ARCANE SHOP"
                android:textColor="#FFBB00"
                android:textSize="36sp"
                android:textStyle="bold"
                android:fontFamily="serif"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Summon entities to harvest Orbs"
                android:textColor="#AAAAAA"
                android:textSize="16sp"
                android:fontFamily="serif"
                android:layout_marginBottom="32dp"/>

            <Button
                android:id="@+id/btnBuyTier1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Arcane Wisp\nGenerates 1 Orb/s | Owned: 0\nCost: 50 🔮"
                android:backgroundTint="#2E1A47"
                android:textColor="#FFFFFF"
                android:padding="16dp"
                android:layout_marginBottom="16dp"/>

            <Button
                android:id="@+id/btnBuyTier2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Mystic Relic\nGenerates 10 Orbs/s | Owned: 0\nCost: 500 🔮"
                android:backgroundTint="#2E1A47"
                android:textColor="#FFFFFF"
                android:padding="16dp"
                android:layout_marginBottom="16dp"/>

            <Button
                android:id="@+id/btnBuyTier3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Void Core\nGenerates 100 Orbs/s | Owned: 0\nCost: 5000 🔮"
                android:backgroundTint="#2E1A47"
                android:textColor="#FFFFFF"
                android:padding="16dp"
                android:layout_marginBottom="32dp"/>

            <Button
                android:id="@+id/btnCloseShop"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Close Shop"
                android:backgroundTint="#660000"
                android:textColor="#FFFFFF"
                android:padding="16dp"/>
        </LinearLayout>
    </FrameLayout>
</FrameLayout>